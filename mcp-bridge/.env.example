# SheetStorm MCP Bridge Configuration
# Copy this file to .env and fill in your values

# --- Required: SheetStorm backend URL ---
# Point this at your SheetStorm instance's API endpoint
SHEETSTORM_API_URL=https://your-sheetstorm-instance.com/api/v1

# --- Authentication (choose one method) ---

# Method 1: Username/Password (recommended for personal use)
SHEETSTORM_USERNAME=your-email@example.com
SHEETSTORM_PASSWORD=your-password

# Method 2: API Token (if you have one)
# SHEETSTORM_API_TOKEN=your-jwt-token

# --- Optional ---
# LOG_LEVEL=INFO
# HTTP_TIMEOUT=30
# HTTP_MAX_RETRIES=2
